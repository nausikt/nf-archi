
manifest {
    name            = 'nausikt/nf-archi'
    description     = 'Archi benchmarking, bootstrapping and prelabelling pipeline'
    author          = 'Nausikt'
    mainScript      = 'main.nf'
    nextflowVersion = '>=25.10.0'
    version         = '0.1.0'
}

plugins {
    id 'nf-schema@2.2.0'
}

validation {
    help {
        enabled = true
    }
    summary {
        beforeText = "Pipeline starting..."
    }
}

params {
    outdir = "results"

    embed {
        endpoint   = "http://submit76.mit.edu:7870"
        model      = "qwen3-embedding:8b"
        text_fields = ['question', 'answer']
        batch_size = 64
    }

    cluster {
        runs = "${projectDir}/assets/cluster/runs.json"
        seed = 42

        grid = null

        // min mean co-association for samples to stay in the same consensus cluster
        consensus_threshold = 0.5
    }

    anchors {
        // fields of each anchor concatenated before embedding (same space as data)
        text_fields = ['name', 'definition']

        // user priors for pre-labeling, grouped by kind (section name == kind):
        //   categories | tags | flags. Absent -> the overlay is skipped.
        // provide via -params-file (see assets/examples/params/demo.yaml)
    }

    assign {
        top_k = 3
    }

    representatives {
        n_medoid   = 3
        n_boundary = 5     // the ambiguous review queue — usually want more
        n_outlier  = 3
    }
}

profiles {

    // Minimal demo  : nextflow run . -profile demo_bootstrapping,conda
    //   -> clusters from assets/cluster/runs.json, anchor overlay skipped.
    // Full demo      : add  -params-file assets/examples/params/demo.yaml
    //   -> grid sweep + anchor pre-labeling overlay.
    demo_bootstrapping {
        params {
            workflow = 'bootstrapping'
            input    = "${projectDir}/assets/tests/inputs/2026-06-06/"
        }
    }

    demo_prelabelling {
        params {
            workflow = 'prelabelling'
            input    = "${projectDir}/assets/tests/inputs/2026-06-06/"
        }
    }

    demo_benchmarking {
        params {
            workflow = 'benchmarking'
            queries  = "${projectDir}/assets/tests/inputs/2026-06-06/"
            configs  = "${projectDir}/assets/tests/configs/"
        }
    }

    test {
        params {
            outdir = "test_results"
        }
        process {
            cpus   = 1
            memory = '2.GB'
        }
    }

    docker {
        docker.enabled = true
    }

    conda {
        conda.enabled = true
        conda.useMicromamba = true
    }

    singularity {
        singularity.enabled = true
    }
}
